{%- set vm_name = "provides-vpn-ivpn" -%}

user:
  'dom0 or {{ vm_name }}-f42':
    - templates.provides-vpn-ivpn.on-fedora
  'dom0 or {{ vm_name }}-k17':
    - templates.provides-vpn-ivpn.on-kicksecure
  '{{ vm_name }}-f42':
    - common
    - common.hardening
    - common.hardening.hardened-malloc
    - common.theme
  '{{ vm_name }}-k17':
    - common
    - common.hardening.kicksecure

