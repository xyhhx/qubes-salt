{%- load_yaml as osfamily_map -%}
RedHat:
  pkgs:
    - breeze-gtk
    - breeze-icon-theme
    - breeze-icon-theme-fedora
    - breeze-cursor-theme
  prefs:
    theme:
      gtk: Breeze-Dark
      icon: 'Breeze Dark'
      cursor: 'Breeze Dark'
Debian:
  pkgs:
    - breeze-gtk-theme
    - breeze-icon-theme
    - breeze-cursor-theme
  prefs:
    theme:
      gtk: Breeze-Dark
      icon: 'Breeze Dark'
      cursor: 'Breeze Dark'
{%- endload -%}
{%- set ui = salt['grains.filter_by'](osfamily_map, default={}) -%}
