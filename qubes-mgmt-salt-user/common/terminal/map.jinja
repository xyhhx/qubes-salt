{%- from 'utils/user_info.jinja' import user with context -%}

{%- import_yaml tpldir ~ '/defaults.yml' as defaults with context -%}
{%- import_yaml tpldir ~ '/maps/grains.os_family.yml' as osfamily_map -%}
{%- import_yaml tpldir ~ '/maps/pillar.qubes_type.yml' as qubestype_map with context -%}

{%- set terminal = {} -%}
{%- for to_merge in [
  defaults,
  salt['grains.filter_by'](osfamily_map, default={}),
  salt['pillar.filter_by'](qubestype_map, 'qubes:type', default={})
] -%}
  {%- do salt['defaults.merge'](terminal, to_merge, in_place=true) -%}
{%- endfor -%}

