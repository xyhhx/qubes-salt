{%- from "common/defaults/qvm_defaults.jinja" import dvm_defaults, offline_patch -%}
{%- set template_name = "on-fedora-43-minimal" -%}

{%- load_yaml as vm_defaults -%}
present:
  - template: "{{ template_name }}"
features:
  - enable:
    - service.hardened_malloc
{%- endload -%}

{%- set vm = {} -%}
{%- do salt["defaults.merge"](vm, dvm_defaults, merge_lists=true, in_place=true) -%}
{%- do salt["defaults.merge"](vm, { "prefs": vm.present }, merge_lists=true, in_place=true) -%}
{%- do salt["defaults.merge"](vm, vm_defaults, merge_lists=true, in_place=true) -%}
{%- do salt["defaults.merge"](vm, { "prefs": vm.present }, merge_lists=true, in_place=true) -%}
{%- do salt["defaults.merge"](vm,
  salt["pillar.get"]("user_qvms:dispvms:dvm_fedora_43_minimal", default={}),
  merge_lists=true,
  in_place=true
) -%}

{%- set offline_vm = {} -%}
{%- do salt["defaults.merge"](offline_vm, vm, merge_lists=true, in_place=true) -%}
{%- do salt["slsutil.update"](offline_vm, offline_patch, recursive_update=true, merge_lists=true) -%}
{#- vim: set ft=salt syntax=salt.jinja ts=2 sw=2 sts=2 et : -#}
