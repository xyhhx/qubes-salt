{%- from "common/defaults/qvm_defaults.jinja" import dvm_defaults -%}

{%- set template_name = "uses-stack-dev" -%}

{%- load_yaml as dvm_opts -%}
present:
  - template: "{{ template_name }}"
prefs:
  - template: "{{ template_name }}"
  - memory: 8000
  - maxmem: 16000
  - vcpus: 4
features:
  - enable:
    - appmenus-dispvm
    - service.qubes-ctap-proxy
    - service.split-gpg2-client
  - set:
    - menu-items: Alacritty.desktop
    - menu-favorites: "@disp:Alacritty"
tags:
  - add:
    - onlykey-ssh-client
{%- endload -%}

{%- set vm = {} -%}
{%- do salt["defaults.merge"](vm, dvm_defaults, merge_lists=true, in_place=true) -%}
{%- do salt["defaults.merge"](vm, dvm_opts, merge_lists=true, in_place=true) -%}
{%- do salt["defaults.merge"](vm, { "prefs": dvm_opts.present }, merge_lists=true, in_place=true) -%}

