{%- import_yaml "./defaults.yml" as defaults -%}

{%- set ok_agent_pkg = {} -%}
{%- do salt["defaults.merge"](ok_agent_pkg, defaults["ok_gpg_agent"], in_place=true, merge_lists=true) -%}
{%- do salt["defaults.merge"](ok_agent_pkg, salt["pillar.get"]("user_qvms:templates:provides_onlykey_agent:ok_gpg_pkg", default={}), in_place=true, merge_lists=true) -%}

{%- set download_url = "https://github.com/svareille/OnlyKey-gpg-agent/releases/download/" | path_join(ok_agent_pkg.release.version, ok_agent_pkg.release_asset) -%}
{%- do salt["defaults.merge"](ok_agent_pkg, { "download_url": download_url }, in_place=true, merge_lists=true) -%}

