#!/bin/env bash
set -eu

missing_env() {
  printf "The environment variable %s is required but not set. Exiting" "${1}"
  exit 1
}

if [[ -z "${GUEST}" ]]; then missing_env "GUEST"; fi
if [[ -z "${SRC_DIR}" ]]; then missing_env "SRC_DIR"; fi

set -x

# shellcheck disable=SC2016
qvm-run "${GUEST}" 'cd ${SRC_DIR} && make bundle'
# shellcheck disable=SC2016
qvm-run -p "${GUEST}" 'cat ${SRC_DIR}/.bundles/qubes-mgmt-salt-user' > /tmp/qubes-mgmt-salt-user.bundle </dev/null

sudo install -dD -oroot -groot -m0755 "${SRC_DIR}"
pushd "${SRC_DIR}"
sudo git init -b main
sudo git pull /tmp/qubes-mgmt-salt-user.bundle
# shellcheck disable=SC2016
sed 's/GUEST=/&${GUEST}/' .env.example | sudo tee .env >/dev/null || true
sudo make install
popd

