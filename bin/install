#!/bin/env bash
set -xeu

qvm-run ${GUEST} 'cd ${SRC_DIR} && make bundle'
qvm-run -p ${GUEST} 'cat ${SRC_DIR}/.bundles/qubes-mgmt-salt-user' > /tmp/qubes-mgmt-salt-user.bundle </dev/null

sudo install -dD -oroot -groot -m0755 ${SRC_DIR}
pushd ${SRC_DIR}
sudo git init -b main
sudo git pull /tmp/qubes-mgmt-salt-user.bundle
sed 's/GUEST=/&${GUEST}/' .env.example | sudo tee .env >/dev/null
sudo make install
popd

