{# vim: set syn=salt ts=2 sw=2 sts=2 et : #}

{%- set vm_name = salt["pillar.get"]("vm_names:templates:uses:thunderbird", "uses-app-thunderbird")  -%}

user:
  'dom0 or {{ vm_name }}':
    - templates.uses-app-thunderbird
  '{{ vm_name }}':
    - common
    - common.pkgs.networking
    - common.pkgs.sequoia-pgp
