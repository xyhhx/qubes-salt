# vim: set syn=yaml ft=sls ts=2 sw=2 sts=2 et :
---

{% set vm_name = "provides-appimage" %}

user:
  dom0:
    - templates.provides-appimage.vm
  '{{ vm_name }}':
    - common.dconf
    - common.pkgs.base
    - common.pkgs.networking
    - common.pkgs.update
    - common.terminal
    - common.theme
    - common.xdpi
    - templates.provides-appimage.configure
