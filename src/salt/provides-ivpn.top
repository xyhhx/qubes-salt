# vim: set syn=yaml ft=sls ts=2 sw=2 sts=2 et :
---

{% set vm_name = pillar.names.templates.providers.ivpn %}

user:
  dom0:
    - templates.provides-ivpn.vm
  '{{ vm_name }}':
    - common.pkgs.update
    - common.pkgs.base
    - common.pkgs.hardened_malloc
    - common.pkgs.networking
    - common.dconf
    - common.terminal
    - common.theme
    - common.xdpi
    - templates.provides-ivpn.configure
