{# vim: set syn=salt ts=2 sw=2 sts=2 et : #}

{%- set vm_name = salt["pillar.get"]("vm_names:templates:uses:librewolf")  -%}

user:
  'dom0 or {{ vm_name }}':
    - templates.uses-app-librewolf
  '{{ vm_name }}':
    - common
    - common.pkgs.audio
    - common.pkgs.networking
    - common.pkgs.ctap-proxy
