# vim: set syn=yaml ft=sls ts=2 sw=2 sts=2 et :
---

{% set vm_name = "uses-app-trivalent" %}

user:
  dom0:
    - templates.uses-app-trivalent.vm
  '{{ vm_name }}':
    - common.dconf
    - common.pkgs.audio
    - common.pkgs.base
    - common.pkgs.hardened_malloc
    - common.pkgs.networking
    - common.pkgs.update
    - common.terminal
    - common.theme
    - common.xdpi
    - templates.uses-app-trivalent.configure
