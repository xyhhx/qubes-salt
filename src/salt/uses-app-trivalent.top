# vim: set syntax=yaml ts=2 sw=2 sts=2 et :

---
{% set vm_name = "dvm-trivalent" %}

user:
  dom0:
    - templates.uses-app-trivalent.vm
  '{{ vm_name }}':
    - common.pkgs.common
    - common.pkgs.hardened_malloc
    - common.pkgs.networking
    - common.pkgs.audio
    - common.theme.init
    - common.terminal.init
    - templates.uses-app-trivalent.configure
