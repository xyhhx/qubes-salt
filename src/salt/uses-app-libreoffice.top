# vim: set syn=yaml ft=sls ts=2 sw=2 sts=2 et :
---

{% set vm_name = "uses-app-libreoffice" %}

user:
  dom0:
    - templates.uses-app-libreoffice.vm
  '{{ vm_name }}':
    - common.pkgs.update
    - common.pkgs.base
    - common.pkgs.hardened_malloc
    - common.dconf
    - common.theme
    - common.terminal
    - common.xdpi
    - templates.uses-app-libreoffice.configure
