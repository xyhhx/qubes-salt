# vim: set syntax=yaml ts=2 sw=2 sts=2 et :

---
{% set vm_name = pillar.names.templates.providers.usb %}

user:
  dom0:
    - templates.provides-usb.vm
  '{{ vm_name }}':
    - common.pkgs.base
    - common.pkgs.hardened_malloc
    - common.dconf
    - common.terminal
    - common.theme
    - templates.provides-usb.configure
