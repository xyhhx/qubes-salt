{# vim: set syn=salt ts=2 sw=2 sts=2 et : #}

{%- set vm_name = salt["pillar.get"]("vm_names:templates:providers:gui") -%}

user:
  'dom0 or {{ vm_name }}':
    - templates.provides-gui
  '{{ vm_name }}':
    - common.pkgs.base
    - common.theme
    - common.custom-themes.Windows-10-Darker
    - common.terminal
