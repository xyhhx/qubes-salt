# vim: set syntax=yaml ts=2 sw=2 sts=2 et :

---
{% set vm_name = "uses-stack-dev-f41" %}

user:
  dom0:
    - templates.uses-stack-dev-f41.vm
  '{{ vm_name }}':
    - common.pkgs.base
    - common.pkgs.hardened_malloc
    - common.pkgs.docker
    - common.pkgs.neovim
    - common.pkgs.rustup
    - common.oh-my-zsh.init
    - common.theme.init
    - common.terminal.init
    - templates.uses-stack-dev-f41.configure
