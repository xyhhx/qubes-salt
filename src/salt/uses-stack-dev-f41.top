# vim: set syn=salt ts=2 sw=2 sts=2 et :
---

{%- set vm_name = salt["pillar.get"]("names:templates:uses:dev_f41")  -%}

user:
  'dom0 or {{ vm_name }}':
    - templates.uses-stack-dev-f41
  '{{ vm_name }}':
    - common
    - common.pkgs.ctap-proxy
    - common.pkgs.docker
    - common.pkgs.neovim
    - common.pkgs.networking
    - common.pkgs.split-gpg
