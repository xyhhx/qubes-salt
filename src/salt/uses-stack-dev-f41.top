# vim: set ts=2 sw=2 sts=2 et :

---
{% set vm_name = "uses-stack-dev-f41" %}

user:
  dom0:
    - templates.uses-stack-dev-f41.vm
  '{{ vm_name }}':
    - common.dconf
    - common.pkgs.base
    - common.pkgs.docker
    - common.pkgs.hardened_malloc
    - common.pkgs.neovim
    - common.pkgs.networking
    - common.pkgs.split-gpg
    - common.pkgs.update
    - common.terminal
    - common.theme
    - common.xdpi
    - templates.uses-stack-dev-f41.configure
