# vim: set syn=yaml ft=sls ts=2 sw=2 sts=2 et :
---

{% set vm_name = pillar.names.templates.stacks.dev_f41 %}

user:
  'dom0 or {{ vm_name }}':
    - templates.{{ vm_name }}
  '{{ vm_name }}':
    - common
    - common.pkgs.ctap-proxy
    - common.pkgs.docker
    - common.pkgs.neovim
    - common.pkgs.networking
    - common.pkgs.split-gpg
