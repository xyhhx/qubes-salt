# vim: set syntax=yaml ts=2 sw=2 sts=2 et :

---
{% set vm_name = "uses-app-keepassxc" %}

user:
  dom0:
    - templates.uses-app-keepassxc.vm
  '{{ vm_name }}':
    - common.pkgs.update
    - common.pkgs.base
    - common.pkgs.hardened_malloc
    - common.dconf
    - common.theme
    - common.terminal
    - common.xdpi
    - templates.uses-app-keepassxc.configure
