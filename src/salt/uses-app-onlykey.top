{# vim: set syn=salt ts=2 sw=2 sts=2 et : #}

{%- set vm_name = salt["pillar.get"]("vm_names:templates:uses:onlykey", "uses-app-onlykey") -%}

user:
  'dom0 or {{ vm_name }}':
    - templates.uses-app-onlykey
  '{{ vm_name }}':
    - common.pkgs.update
    - common.pkgs.base
    - common.terminal
    - common.theme
    - common.xdpi

