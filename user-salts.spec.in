Name:  	  user-salts
Version:  @VERSION@
Release:  %autorelease
Summary:  xyhhx's personal salt states

Group:  	  Qubes
License:    HL3-FULL
BuildArch:  noarch

BuildRequires: make
BuildRequires: rpmautospec

Source0: %{name}-%{version}.tar.gz

%description
xyhhx's personal salt states

%prep
%setup -q -n %{name}-%{version}

%install
make install-dom0 DESTDIR=${RPM_BUILD_ROOT}

