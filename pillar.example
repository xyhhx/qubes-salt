---
# ui related preferences
ui:
  prefs:
    theme:
      cursor: "Adwaita"
      gtk: "Adwaita"
      icon: "Adwaita"
    fonts:
      mono: "IBM Plex Mono 10"
      sans: "Liberation Sans 10"
      serif: "Liberation Serif 10"

# set the defaults for qubes created with salts from this repo
qvm_defaults:
  prefs:
    - label: gray

    - memory: 400
    - maxmem: 2000
    - vcpus: 1

    - kernel: "*default*"
    - kernelopts: "*default*"
    - pci-strictreset: true
    - virt-mode: pvh

    - audiovm: "*default*"
    - guivm: "*default*"
    - netvm: "*default*"

    - autostart: false
    - debug: false
    - default-user: user
    - include-in-backups: false
    - internal: false
    - qrexec-timeout: 120

  features:
    - set:
      - menu-items: Alacritty.desktop
      - default-menu-items: Alacritty.desktop

vm_settings:
  templates:
    uses_app_trivalent:
      celenity_titanium:
        enable: true
        block_extensions: true
        allow_trustworthy_extensions: true
        unbreak_bitwarden: false
        allow_webusb: false

# vim: ft=yaml ts=2 sw=2 sts=2 et :
